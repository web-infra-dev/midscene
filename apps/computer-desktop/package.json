{
  "name": "computer-desktop",
  "private": true,
  "version": "1.3.10",
  "description": "Midscene Computer Playground desktop app",
  "author": "midscene team",
  "license": "MIT",
  "main": "./main.cjs",
  "scripts": {
    "build:deps": "pnpm --filter @midscene/computer... --filter @midscene/playground... build",
    "build:static": "pnpm --filter computer-playground build",
    "build": "pnpm run build:deps && pnpm run build:static",
    "start": "electron .",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:mac:intel": "pnpm run build && electron-builder --mac --x64"
  },
  "dependencies": {
    "@midscene/computer": "workspace:*",
    "@midscene/playground": "workspace:*",
    "@midscene/shared": "workspace:*"
  },
  "devDependencies": {
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12"
  },
  "optionalDependencies": {
    "@img/sharp-darwin-x64": "0.34.3",
    "@img/sharp-libvips-darwin-x64": "1.2.0"
  }
}
