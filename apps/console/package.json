{
  "name": "console",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "build": "pnpm run build:renderer && pnpm run build:electron",
    "build:renderer": "rsbuild build",
    "build:electron": "node scripts/prepare-electron.mjs",
    "dev": "concurrently -k \"pnpm run dev:renderer\" \"pnpm run dev:electron\"",
    "dev:renderer": "rsbuild dev --port 3901 --open false",
    "dev:electron": "wait-on tcp:3901 && cross-env MIDSCENE_CONSOLE_RENDERER_URL=http://127.0.0.1:3901 electron .",
    "preview": "rsbuild preview",
    "package": "pnpm run build && electron-builder --publish never",
    "package:linux": "pnpm run build && electron-builder --linux AppImage --publish never"
  },
  "dependencies": {
    "@midscene/android": "workspace:*",
    "@midscene/computer": "workspace:*",
    "@midscene/harmony": "workspace:*",
    "@midscene/ios": "workspace:*",
    "@midscene/playground": "workspace:*",
    "@midscene/playground-app": "workspace:*",
    "antd": "^5.21.6",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.6.15",
    "@rsbuild/plugin-less": "^1.5.0",
    "@rsbuild/plugin-node-polyfill": "1.4.2",
    "@rsbuild/plugin-react": "^1.4.1",
    "@rsbuild/plugin-svgr": "^1.2.2",
    "@rsbuild/plugin-type-check": "^1.3.2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "less": "^4.2.0",
    "rsbuild-plugin-workspace-dev": "0.0.1",
    "typescript": "^5.8.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.midscene.console",
    "productName": "Midscene Console",
    "directories": {
      "output": "release"
    },
    "files": ["dist/**/*", "dist-electron/**/*", "package.json"],
    "linux": {
      "target": ["AppImage"],
      "category": "Development"
    }
  }
}
