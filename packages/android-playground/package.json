{
  "name": "@midscene/android-playground",
  "version": "1.6.0",
  "description": "Android playground for Midscene",
  "main": "./dist/lib/index.js",
  "types": "./dist/types/index.d.ts",
  "module": "./dist/es/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/es/index.mjs",
      "require": "./dist/lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "static", "bin", "README.md"],
  "bin": {
    "midscene-android-playground": "./bin/android-playground",
    "@midscene/android-playground": "./bin/android-playground"
  },
  "scripts": {
    "dev": "npm run build:watch",
    "dev:server": "npm run build && ./bin/playground",
    "prebuild": "node ../android/scripts/download-scrcpy-server.mjs --target=bin/scrcpy-server",
    "build": "rslib build",
    "build:watch": "rslib build --watch --no-clean",
    "prepack": "node ../android/scripts/download-scrcpy-server.mjs --target=bin/scrcpy-server"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.8.6",
    "@midscene/android": "workspace:*",
    "@midscene/core": "workspace:*",
    "@midscene/playground": "workspace:*",
    "@midscene/shared": "workspace:*",
    "@yume-chan/adb": "2.5.1",
    "@yume-chan/adb-scrcpy": "2.3.2",
    "@yume-chan/adb-server-node-tcp": "2.5.2",
    "@yume-chan/scrcpy": "2.3.0",
    "@yume-chan/stream-extra": "2.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "open": "10.1.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@rslib/core": "^0.18.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^18.0.0",
    "gh-release-fetch": "^4.0.3",
    "typescript": "^5.8.3"
  },
  "license": "MIT"
}
