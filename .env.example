# Copy to .env and fill in values. See https://midscenejs.com/model-strategy.html

# --- Recommended (single default model) ---
MIDSCENE_MODEL_FAMILY=qwen3-vl
MIDSCENE_MODEL_NAME=
MIDSCENE_MODEL_API_KEY=
MIDSCENE_MODEL_BASE_URL=

# --- Legacy alias (still supported) ---
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# --- Optional ---
# MIDSCENE_CACHE=true
# MIDSCENE_PLAYGROUND_HOST=127.0.0.1
# MIDSCENE_PLAYGROUND_ALLOW_REMOTE=0

# --- AI tests (vitest) ---
# AITEST=true
